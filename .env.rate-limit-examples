# ============================================================
# Rate Limiting Configuration Examples
# ============================================================
# Copy the appropriate configuration to your .env file
# ============================================================

# ------------------------------------------------------------
# LOAD TESTING / DEVELOPMENT (Very Lenient)
# Use this for JMeter testing with 50-200 users
# ------------------------------------------------------------
AUTH_RATE_LIMIT_WINDOW_MS=300000     # 5 minutes
AUTH_RATE_LIMIT_MAX=1000             # 1000 requests per 5 min
AUTH_RATE_LIMIT_SKIP_SUCCESS=false

# ------------------------------------------------------------
# PRODUCTION - LENIENT (Recommended for most apps)
# Good for user-friendly production environments
# ------------------------------------------------------------
# AUTH_RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# AUTH_RATE_LIMIT_MAX=200            # 200 requests per 15 min
# AUTH_RATE_LIMIT_SKIP_SUCCESS=true  # Only count failed attempts

# ------------------------------------------------------------
# PRODUCTION - STANDARD (Balanced security)
# Default configuration - moderate protection
# ------------------------------------------------------------
# AUTH_RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# AUTH_RATE_LIMIT_MAX=100            # 100 requests per 15 min
# AUTH_RATE_LIMIT_SKIP_SUCCESS=false

# ------------------------------------------------------------
# PRODUCTION - STRICT (High Security)
# Use for sensitive applications
# ------------------------------------------------------------
# AUTH_RATE_LIMIT_WINDOW_MS=600000   # 10 minutes
# AUTH_RATE_LIMIT_MAX=50             # 50 requests per 10 min
# AUTH_RATE_LIMIT_SKIP_SUCCESS=false

# ------------------------------------------------------------
# PRODUCTION - VERY STRICT (Banking/Financial)
# Maximum brute force protection
# ------------------------------------------------------------
# AUTH_RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# AUTH_RATE_LIMIT_MAX=10             # Only 10 attempts
# AUTH_RATE_LIMIT_SKIP_SUCCESS=true  # Only count failures

# ============================================================
# Quick Reference - Time Conversions
# ============================================================
# 1 minute  = 60000 ms
# 5 minutes = 300000 ms
# 10 minutes = 600000 ms
# 15 minutes = 900000 ms
# 30 minutes = 1800000 ms
# 1 hour = 3600000 ms

# ============================================================
# Calculation Examples
# ============================================================
# For 50 concurrent users doing 5 login attempts:
#   50 × 5 = 250 requests needed
#   Set: AUTH_RATE_LIMIT_MAX=500 (with buffer)
#
# For 100 concurrent users doing 5 login attempts:
#   100 × 5 = 500 requests needed
#   Set: AUTH_RATE_LIMIT_MAX=1000 (with buffer)
#
# For 200 concurrent users doing 5 login attempts:
#   200 × 5 = 1000 requests needed
#   Set: AUTH_RATE_LIMIT_MAX=2000 (with buffer)
